# Скопируйте в secrets/secrets.yaml и зашифруйте через sops:
#   sops secrets/secrets.yaml
#
# Первичная настройка:
#   age-keygen -o ~/.config/sops/age/keys.txt
#   sops updatekeys secrets/secrets.yaml

tfs_pat: "your-tfs-personal-access-token"
tfs_git_auth_header: "base64-of-efremov_an:your-tfs-pat"
anthropic_api_key: "your-anthropic-api-key"
waybar_ssh_host: "ssh.example.com"
waybar_ssh_user: "user"
waybar_ssh_port: "22"
waybar_proxy_port: "1050"
waybar_ssh_key_file: "/home/USER/.ssh/id_rsa"
waybar_nats_url: "nats://127.0.0.1:4222"
waybar_nats_creds_file: "/home/USER/.config/nats/context/default.creds"
